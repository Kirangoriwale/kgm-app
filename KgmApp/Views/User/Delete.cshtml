@model KgmApp.Models.User
@{
    ViewData["Title"] = "Delete User";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Users</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <h1 class="h3 text-danger mb-2">Delete User</h1>
        <p class="text-muted mb-4">This action cannot be undone.</p>

        <div class="card border-danger border-opacity-50 shadow-sm mb-4 rounded-3">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>

                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">@Model.Role</dd>

                    <dt class="col-sm-4">Active</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge member-status-badge member-status-yes">Yes</span>
                        }
                        else
                        {
                            <span class="badge member-status-badge member-status-no">No</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="d-flex flex-column flex-sm-row gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
