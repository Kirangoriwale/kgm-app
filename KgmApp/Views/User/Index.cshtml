@model IEnumerable<KgmApp.Models.User>
@{
    ViewData["Title"] = "Users";
    ViewData["PageTitle"] = "Users";
    ViewData["BreadcrumbCurrent"] = "Users";
}

<div class="page-actions d-flex justify-content-end mb-4">
    @if (ViewMenu.Can(ViewData, MenuKeys.SettingsUser, "Add"))
    {
        <a class="btn btn-primary rounded-3 d-inline-flex align-items-center justify-content-center gap-2" asp-action="Create">
            <i class="bi bi-person-plus" aria-hidden="true"></i>
            Add User
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox display-6 d-block mb-3" aria-hidden="true"></i>
            <p class="mb-0">No users available. Use <strong>Add User</strong> to create one.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Role</th>
                        <th class="text-center">Active</th>
                        <th class="text-end text-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-medium">@user.Username</td>
                        <td class="text-break">@user.FullName</td>
                        <td>@user.Role</td>
                        <td class="text-center">
                            @if (user.IsActive)
                            {
                                <span class="badge member-status-badge member-status-yes">Yes</span>
                            }
                            else
                            {
                                <span class="badge member-status-badge member-status-no">No</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-1 flex-wrap justify-content-end action-buttons">
                                @if (ViewMenu.Can(ViewData, MenuKeys.SettingsUser, "Edit"))
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                                }
                                @if (ViewMenu.Can(ViewData, MenuKeys.SettingsUser, "Delete"))
                                {
                                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@user.Id">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
