@model IReadOnlyList<KgmApp.Models.CommitteeMemberCardViewModel>
@{
    ViewData["Title"] = "Committee Members";
    ViewData["PageTitle"] = "Committee Members";
    ViewData["BreadcrumbCurrent"] = "Committee Members";
    var memberPhotoBaseUrl = ViewData["CommitteeMemberPhotoBaseUrl"]?.ToString();
    var memberPhotoAltBaseUrl = ViewData["CommitteeMemberPhotoAltBaseUrl"]?.ToString();
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-people display-6 d-block mb-3" aria-hidden="true"></i>
            No committee members found.
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var row in Model)
        {
            var dialableMobileNo = new string((row.MobileNo ?? string.Empty).Where(char.IsDigit).ToArray());
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 h-100 committee-member-card">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex align-items-start gap-3 committee-member-top">
                            <div class="committee-member-avatar rounded-circle d-inline-flex align-items-center justify-content-center">
                                @if (!string.IsNullOrWhiteSpace(memberPhotoBaseUrl))
                                {
                                    <img class="committee-member-avatar-img rounded-circle"
                                         data-photo-base-url="@memberPhotoBaseUrl"
                                         data-photo-alt-base-url="@memberPhotoAltBaseUrl"
                                         data-member-id="@row.MemberId"
                                         alt="@row.Name"
                                         loading="lazy" />
                                }
                                <i class="bi bi-person-fill committee-member-avatar-fallback" aria-hidden="true"></i>
                            </div>
                            <div class="committee-member-content min-w-0 d-flex flex-column">
                                <h2 class="h5 mb-1 text-dark committee-member-name">@row.Name</h2>
                                <div class="committee-member-designation">@row.Designation</div>
                                <a class="committee-member-contact-link text-decoration-none fw-semibold d-inline-flex align-items-center gap-2 mt-2" href="tel:@dialableMobileNo">
                                    <i class="bi bi-telephone-fill small" aria-hidden="true"></i>
                                    <span>@row.MobileNo</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            const photoExtensions = [".jpg", ".jpeg", ".png", ".webp", ".JPG", ".JPEG", ".PNG", ".WEBP"];
            const images = document.querySelectorAll(".committee-member-avatar-img[data-photo-base-url][data-member-id]");

            images.forEach(function (img) {
                const baseUrl = img.getAttribute("data-photo-base-url");
                const altBaseUrl = img.getAttribute("data-photo-alt-base-url");
                const memberId = img.getAttribute("data-member-id");
                const fallback = img.nextElementSibling;
                const baseUrls = [baseUrl, altBaseUrl].filter(Boolean);
                const candidateIds = [memberId]
                    .filter(function (value) { return value && value.trim(); });
                const candidateBaseUrls = [];
                baseUrls.forEach(function (url) {
                    const normalized = url.replace(/\/$/, "");
                    candidateBaseUrls.push(normalized);

                    // Common Supabase setup: bucket name folder exists inside the same bucket.
                    if (!normalized.endsWith("/member-photos")) {
                        candidateBaseUrls.push(normalized + "/member-photos");
                    }
                });
                let baseUrlIndex = 0;

                if (candidateBaseUrls.length === 0 || candidateIds.length === 0) {
                    img.style.display = "none";
                    if (fallback) fallback.style.display = "inline-flex";
                    return;
                }

                let candidateIdIndex = 0;
                let extensionIndex = 0;
                const loadNext = function () {
                    if (baseUrlIndex >= candidateBaseUrls.length) {
                        img.style.display = "none";
                        if (fallback) fallback.style.display = "inline-flex";
                        return;
                    }

                    if (extensionIndex >= photoExtensions.length) {
                        extensionIndex = 0;
                        candidateIdIndex += 1;
                        if (candidateIdIndex >= candidateIds.length) {
                            candidateIdIndex = 0;
                            baseUrlIndex += 1;
                        }
                    }

                    if (baseUrlIndex >= candidateBaseUrls.length) {
                        img.style.display = "none";
                        if (fallback) fallback.style.display = "inline-flex";
                        return;
                    }

                    const nextSrc = candidateBaseUrls[baseUrlIndex].replace(/\/$/, "") + "/" + encodeURIComponent(candidateIds[candidateIdIndex]) + photoExtensions[extensionIndex];
                    extensionIndex += 1;
                    img.src = nextSrc;
                };

                img.onerror = loadNext;
                img.onload = function () {
                    img.style.display = "block";
                    if (fallback) fallback.style.display = "none";
                };

                loadNext();
            });
        })();
    </script>
}
