@model KgmApp.Models.MemberPendingDetailsViewModel
@{
    ViewData["Title"] = "Pending details";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h4 mb-1 text-dark">Amount pending — details</h1>
        <p class="text-muted mb-0 small">@Model.MemberName</p>
    </div>
    <a asp-action="MemberDashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Back to dashboard
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-wrap justify-content-between align-items-baseline gap-2 mb-3">
            <span class="text-muted text-uppercase small fw-semibold">Grand total (pending)</span>
            <span class="h4 mb-0 text-danger">₹ @Model.GrandPendingTotal.ToString("N2")</span>
        </div>
        <p class="small text-muted mb-0">Pending is expected fees up to today minus amounts already paid, split between contributions and registration.</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header bg-white border-0 pt-3 px-3 px-md-4 pb-0">
        <h2 class="h6 mb-0 text-dark">Contributions</h2>
    </div>
    <div class="card-body px-3 px-md-4 pt-3 pb-0">
        <dl class="row small mb-3">
            <dt class="col-sm-5 col-md-4 text-muted">Expected (to date)</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.ExpectedContributionTotal.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted">Paid</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.PaidContributionTotal.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted fw-semibold text-dark">Pending</dt>
            <dd class="col-sm-7 col-md-8 mb-0 fw-semibold">₹ @Model.PendingContribution.ToString("N2")</dd>
        </dl>
    </div>
    <div class="card-body p-0 border-top">
        @if (Model.ContributionByPeriod.Count == 0)
        {
            <p class="text-muted small px-3 px-md-4 py-3 mb-0">No contribution periods in scope.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Period</th>
                            <th scope="col" class="text-end">Expected</th>
                            <th scope="col" class="text-end">Paid in period</th>
                            <th scope="col" class="text-end">Shortfall</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.ContributionByPeriod)
                        {
                            var shortfall = Math.Max(0m, line.ExpectedFee - line.PaidInPeriod);
                            <tr>
                                <td>@line.PeriodLabel</td>
                                <td class="text-end text-nowrap">₹ @line.ExpectedFee.ToString("N2")</td>
                                <td class="text-end text-nowrap">₹ @line.PaidInPeriod.ToString("N2")</td>
                                <td class="text-end text-nowrap @(shortfall > 0 ? "text-danger" : "")">₹ @shortfall.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header bg-white border-0 pt-3 px-3 px-md-4 pb-0">
        <h2 class="h6 mb-0 text-dark">Registration</h2>
    </div>
    <div class="card-body px-3 px-md-4">
        <dl class="row small mb-0">
            <dt class="col-sm-5 col-md-4 text-muted">Fee per person</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.RegistrationFeePerPerson.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted">SubMembers</dt>
            <dd class="col-sm-7 col-md-8 mb-1">@Model.SubMemberCount</dd>
            <dt class="col-sm-5 col-md-4 text-muted">Expected total</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.ExpectedRegistrationTotal.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted">Paid (member)</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.PaidMemberRegistration.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted">Paid (SubMembers)</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.PaidSubMemberRegistration.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted">Registration paid total</dt>
            <dd class="col-sm-7 col-md-8 mb-1">₹ @Model.RegistrationPaidTotal.ToString("N2")</dd>
            <dt class="col-sm-5 col-md-4 text-muted fw-semibold text-dark">Registration pending</dt>
            <dd class="col-sm-7 col-md-8 mb-0 fw-semibold">₹ @Model.PendingRegistration.ToString("N2")</dd>
        </dl>
    </div>
</div>
