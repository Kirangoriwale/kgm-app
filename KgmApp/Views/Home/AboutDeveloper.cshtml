@{
    ViewData["Title"] = "About Developer";
    ViewData["PageTitle"] = "About Developer";
    ViewData["BreadcrumbCurrent"] = "About Developer";
    var photoBaseUrl = ViewData["AboutDeveloperPhotoBaseUrl"]?.ToString();
    var photoAltBaseUrl = ViewData["AboutDeveloperPhotoAltBaseUrl"]?.ToString();
    var directPhotoUrl = !string.IsNullOrWhiteSpace(photoBaseUrl)
        ? $"{photoBaseUrl.TrimEnd('/')}/1.jpg"
        : null;
}

@section Head {
    <style>
        .developer-shell {
            background: radial-gradient(circle at 0% 0%, #f1f6ff 0%, #f8faff 45%, #ffffff 100%);
            border-radius: 1.5rem;
            border: 1px solid #e7eef8;
            padding: 0.65rem;
        }

        .developer-card {
            border-radius: 1.2rem;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 14px 35px rgba(13, 43, 89, 0.09);
        }

        .developer-card-left {
            min-height: 300px;
            color: #fff;
            background:
                radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.02) 42%, transparent 60%),
                linear-gradient(160deg, #071b47 0%, #0f3675 54%, #15509e 100%);
        }

        .developer-card-slope {
            min-height: 300px;
            background: linear-gradient(160deg, #071b47 0%, #0f3675 54%, #15509e 100%);
            clip-path: polygon(0 0, 100% 0, 0 100%);
        }

        .developer-avatar {
            width: 118px;
            height: 118px;
            border-radius: 50%;
            border: 3px solid rgba(255, 255, 255, 0.95);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.16);
            font-size: 2rem;
            font-weight: 700;
            overflow: hidden;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
        }

        .developer-avatar-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .developer-title {
            letter-spacing: 0.2px;
        }

        .developer-subtitle {
            color: rgba(236, 244, 255, 0.85);
        }

        .developer-divider {
            width: 58px;
            height: 3px;
            background: linear-gradient(90deg, #51a5ff 0%, #9ecbff 100%);
            border-radius: 999px;
            margin: 0.75rem auto;
        }

        .developer-tagline {
            color: rgba(236, 244, 255, 0.78);
        }

        .developer-card-right {
            min-height: 300px;
            background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
        }

        .developer-main-heading {
            color: #102c57;
        }

        .developer-info-row {
            border-bottom: 1px solid #e9eff8;
            padding-bottom: 0.58rem;
            margin-bottom: 0.58rem;
            color: #15345f;
        }

        .developer-info-row i {
            color: #1c72f2;
        }

        .developer-social-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.38rem;
            padding: 0.42rem 0.85rem;
            border-radius: 999px;
            background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
            color: #fff;
            font-weight: 600;
            font-size: 0.84rem;
            text-decoration: none;
            box-shadow: 0 6px 14px rgba(13, 110, 253, 0.26);
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .developer-social-chip:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 9px 18px rgba(13, 110, 253, 0.3);
        }

        .developer-footnote {
            color: #3f5f90;
            font-weight: 500;
        }

        @@media (max-width: 991.98px) {
            .developer-card-slope {
                display: none;
            }

            .developer-card-left,
            .developer-card-right {
                min-height: auto;
            }
        }
    </style>
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3 p-md-4">
        <div class="developer-shell">
            <div class="developer-card">
                <div class="row g-0">
                    <div class="col-lg-4 p-4 p-md-5 text-center d-flex flex-column justify-content-center developer-card-left">
                    <div class="developer-avatar mx-auto mb-3">
                        @if (!string.IsNullOrWhiteSpace(photoBaseUrl))
                        {
                            <img class="developer-avatar-img"
                                 src="@directPhotoUrl"
                                 data-photo-base-url="@photoBaseUrl"
                                 data-photo-alt-base-url="@photoAltBaseUrl"
                                 data-member-id="1"
                                 alt="Kiran Goriwale"
                                 loading="lazy" />
                        }
                        <span class="developer-avatar-fallback">KG</span>
                    </div>
                    <h5 class="mb-1 developer-title">Kiran Goriwale</h5>
                    <div class="small developer-subtitle">Software Developer</div>
                    <div class="developer-divider"></div>
                    <div class="small developer-tagline">Turning ideas into smart solutions.</div>
                    </div>
                    <div class="col-lg-1 d-none d-lg-block developer-card-slope"></div>
                    <div class="col-lg-7 p-3 p-md-4 developer-card-right">
                        <div class="developer-info-row">
                            <h4 class="mb-1 developer-main-heading">Kiran Goriwale</h4>
                            <div class="text-muted">Software Developer</div>
                        </div>
                        <div class="developer-info-row">
                            <div><i class="bi bi-envelope me-2"></i>kiran.goriwale@gmail.com</div>
                        </div>
                        <div class="developer-info-row">
                            <div><i class="bi bi-telephone me-2"></i>+91 98921 40241</div>
                        </div>
                        <div class="developer-info-row">
                            <div><i class="bi bi-geo-alt me-2"></i>India</div>
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-3 mt-3">
                            <a class="developer-social-chip"
                               href="https://wa.me/919892140241"
                               target="_blank"
                               rel="noopener noreferrer">
                                <i class="bi bi-whatsapp"></i>WhatsApp
                            </a>
                            <span class="small ms-lg-auto developer-footnote">Built with Passion 💙</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const photoExtensions = [".jpg", ".jpeg", ".png", ".webp", ".JPG", ".JPEG", ".PNG", ".WEBP"];
            const img = document.querySelector(".developer-avatar-img[data-member-id]");
            if (!img) return;

            const fallback = img.parentElement ? img.parentElement.querySelector(".developer-avatar-fallback") : null;
            const baseUrl = img.getAttribute("data-photo-base-url") || "";
            const altBaseUrl = img.getAttribute("data-photo-alt-base-url") || "";
            const memberId = img.getAttribute("data-member-id");
            const initialSrc = img.getAttribute("src") || "";

            const baseUrls = [baseUrl, altBaseUrl].filter(Boolean);
            const candidateBaseUrls = [];
            baseUrls.forEach(function (url) {
                const normalized = url.replace(/\/$/, "");
                candidateBaseUrls.push(normalized);
                if (!normalized.endsWith("/member-photos")) {
                    candidateBaseUrls.push(normalized + "/member-photos");
                }
            });

            // Local static fallbacks (if member photos are stored under wwwroot).
            const localCandidates = [
                "/images/member-photos",
                "/images/members",
                "/images"
            ];

            localCandidates.forEach(function (path) {
                candidateBaseUrls.push(path);
            });

            let baseUrlIndex = 0;
            let extensionIndex = 0;
            let hasTriedInitial = false;

            const showFallback = function () {
                img.style.display = "none";
                if (fallback) fallback.style.display = "inline-flex";
            };

            const showImage = function () {
                img.style.display = "block";
                if (fallback) fallback.style.display = "none";
            };

            const loadNext = function () {
                if (!hasTriedInitial && initialSrc) {
                    hasTriedInitial = true;
                    img.src = initialSrc;
                    return;
                }

                if (!memberId || baseUrlIndex >= candidateBaseUrls.length) {
                    showFallback();
                    return;
                }

                if (extensionIndex >= photoExtensions.length) {
                    extensionIndex = 0;
                    baseUrlIndex += 1;
                }

                if (baseUrlIndex >= candidateBaseUrls.length) {
                    showFallback();
                    return;
                }

                const nextSrc = candidateBaseUrls[baseUrlIndex].replace(/\/$/, "") + "/" + encodeURIComponent(memberId) + photoExtensions[extensionIndex];
                extensionIndex += 1;
                img.src = nextSrc;
            };

            img.onerror = loadNext;
            img.onload = showImage;

            // If the initial src already loaded before handlers were attached, show it immediately.
            if (initialSrc && img.complete && img.naturalWidth > 0) {
                showImage();
                return;
            }

            loadNext();
        })();
    </script>
}
