@model KgmApp.Models.MemberPaidDetailsViewModel
@{
    ViewData["Title"] = "Payment details";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="h4 mb-1 text-dark">Total paid — details</h1>
        <p class="text-muted mb-0 small">@Model.MemberName</p>
    </div>
    <a asp-action="MemberDashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Back to dashboard
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-wrap justify-content-between align-items-baseline gap-2 mb-0">
            <span class="text-muted text-uppercase small fw-semibold">Grand total (paid)</span>
            <span class="h4 mb-0 text-success">₹ @Model.GrandTotal.ToString("N2")</span>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header bg-white border-0 pt-3 px-3 px-md-4 pb-0">
        <h2 class="h6 mb-0 text-dark">Half-yearly contributions</h2>
        <p class="small text-muted mb-0 mt-1">Each recorded payment for you and your SubMembers.</p>
    </div>
    <div class="card-body p-0">
        @if (Model.ContributionPayments.Count == 0)
        {
            <p class="text-muted small px-3 px-md-4 py-3 mb-0">No contribution payments recorded.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">Amount</th>
                            <th scope="col">Mode</th>
                            <th scope="col">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.ContributionPayments.OrderByDescending(x => x.TransactionDate))
                        {
                            <tr>
                                <td>@line.TransactionDate.ToString("dd MMM yyyy")</td>
                                <td class="text-nowrap">₹ @line.Amount.ToString("N2")</td>
                                <td>@line.PaymentMode</td>
                                <td>@line.Description</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th scope="row">Subtotal</th>
                            <td class="fw-semibold text-nowrap">₹ @Model.ContributionsPaidTotal.ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-header bg-white border-0 pt-3 px-3 px-md-4 pb-0">
        <h2 class="h6 mb-0 text-dark">Registration fees</h2>
    </div>
    <div class="card-body p-0">
        @if (Model.RegistrationPayments.Count == 0)
        {
            <p class="text-muted small px-3 px-md-4 py-3 mb-0">No registration payments recorded.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">For</th>
                            <th scope="col">Date</th>
                            <th scope="col">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.RegistrationPayments)
                        {
                            <tr>
                                <td>@line.PartyLabel</td>
                                <td>@line.TransactionDate.ToString("dd MMM yyyy")</td>
                                <td class="text-nowrap">₹ @line.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th scope="row" colspan="2">Subtotal</th>
                            <td class="fw-semibold text-nowrap">₹ @Model.RegistrationPaidTotal.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>
