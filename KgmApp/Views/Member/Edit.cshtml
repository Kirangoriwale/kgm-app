@model KgmApp.Models.Member
@{
    ViewData["Title"] = "Edit Member";
    var subMembers = ViewData["SubMembers"] as IReadOnlyList<KgmApp.Models.SubMember> ?? [];
    var draftSubMember = ViewData["NewSubMember"] as KgmApp.Models.SubMember ?? new KgmApp.Models.SubMember { MemberId = Model.Id, IsActive = true };
}

<div class="row g-4">
    <div class="col-12 col-xl-5">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Members</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>

        <h1 class="h3 mb-4">Edit Member</h1>

        <form asp-action="Edit" method="post" class="card border-0 shadow-sm">
            <input type="hidden" asp-for="Id" />
            <div class="card-body p-4">
                <partial name="_MemberFormFields" model="Model" />
            </div>
            <div class="card-footer bg-white border-top-0 px-4 pb-4 d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
                <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Details</a>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
                <h2 class="h5 mb-0">SubMembers</h2>
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#addSubMemberForm" aria-expanded="false" aria-controls="addSubMemberForm">
                    <i class="bi bi-person-plus me-1" aria-hidden="true"></i>Add SubMember
                </button>
            </div>
            <div class="card-body p-0">
                @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-warning rounded-0 mb-0" role="alert">@errorMessage</div>
                }

                <div id="addSubMemberForm" class="collapse border-bottom">
                    <form asp-action="AddSubMember" method="post" class="p-3 p-md-4">
                        <input type="hidden" name="MemberId" value="@Model.Id" />
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberSrNo" class="form-label">Sr. No.</label>
                                <input id="addSubMemberSrNo" name="SrNo" class="form-control" type="number" value="@draftSubMember.SrNo" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberName" class="form-label">Name</label>
                                <input id="addSubMemberName" name="Name" class="form-control" value="@draftSubMember.Name" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberMobileNo" class="form-label">Mobile</label>
                                <input id="addSubMemberMobileNo" name="MobileNo" class="form-control" value="@draftSubMember.MobileNo" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberEmailId" class="form-label">Email ID</label>
                                <input id="addSubMemberEmailId" name="EmailId" class="form-control" inputmode="email" value="@draftSubMember.EmailId" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberRelation" class="form-label">Relation</label>
                                <input id="addSubMemberRelation" name="Relation" class="form-control" value="@draftSubMember.Relation" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="addSubMemberDesignation" class="form-label">Designation</label>
                                <input id="addSubMemberDesignation" name="Designation" class="form-control" value="@draftSubMember.Designation" />
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    @if (draftSubMember.IsActive)
                                    {
                                        <input id="addSubMemberIsActive" name="IsActive" class="form-check-input" type="checkbox" role="switch" value="true" checked />
                                    }
                                    else
                                    {
                                        <input id="addSubMemberIsActive" name="IsActive" class="form-check-input" type="checkbox" role="switch" value="true" />
                                    }
                                    <input type="hidden" name="IsActive" value="false" />
                                    <label for="addSubMemberIsActive" class="form-check-label">Active</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    @if (draftSubMember.IsRegistrationFormSubmitted)
                                    {
                                        <input id="addSubMemberIsRegistrationFormSubmitted" name="IsRegistrationFormSubmitted" class="form-check-input" type="checkbox" role="switch" value="true" checked />
                                    }
                                    else
                                    {
                                        <input id="addSubMemberIsRegistrationFormSubmitted" name="IsRegistrationFormSubmitted" class="form-check-input" type="checkbox" role="switch" value="true" />
                                    }
                                    <input type="hidden" name="IsRegistrationFormSubmitted" value="false" />
                                    <label for="addSubMemberIsRegistrationFormSubmitted" class="form-check-label">Registration Form Submitted</label>
                                </div>
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">Save SubMember</button>
                            </div>
                        </div>
                    </form>
                </div>

                @if (subMembers.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-6 d-block mb-2" aria-hidden="true"></i>
                        No sub-members found for this member.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-end text-nowrap">Sr. No.</th>
                                    <th>Name</th>
                                    <th>Mobile</th>
                                    <th>Email ID</th>
                                    <th>Relation</th>
                                    <th class="text-center">Active</th>
                                    <th class="text-center">Registration</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var sub in subMembers)
                            {
                                <tr>
                                    <td class="text-end">@sub.SrNo</td>
                                    <td class="fw-medium">@sub.Name</td>
                                    <td>@sub.MobileNo</td>
                                    <td class="text-break">@sub.EmailId</td>
                                    <td>@sub.Relation</td>
                                    <td class="text-center">
                                        @if (sub.IsActive)
                                        {
                                            <span class="badge text-bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">No</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (sub.IsRegistrationFormSubmitted)
                                        {
                                            <span class="badge text-bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">No</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editSubMemberModal"
                                                    data-sub-id="@sub.Id"
                                                    data-sub-srno="@sub.SrNo"
                                                    data-sub-memberid="@Model.Id"
                                                    data-sub-name="@sub.Name"
                                                    data-sub-mobile="@sub.MobileNo"
                                                    data-sub-email="@sub.EmailId"
                                                    data-sub-relation="@sub.Relation"
                                                    data-sub-designation="@sub.Designation"
                                                    data-sub-active="@sub.IsActive"
                                                    data-sub-regsubmitted="@sub.IsRegistrationFormSubmitted">
                                                Edit
                                            </button>
                                            <form asp-action="DeleteSubMember" method="post" class="d-inline">
                                                <input type="hidden" name="memberId" value="@Model.Id" />
                                                <input type="hidden" name="subMemberId" value="@sub.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editSubMemberModal" tabindex="-1" aria-labelledby="editSubMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="EditSubMember" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="editSubMemberModalLabel">Edit SubMember</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editSubMemberId" name="Id" />
                    <input type="hidden" id="editSubMemberMemberId" name="MemberId" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberSrNo" class="form-label">Sr. No.</label>
                            <input id="editSubMemberSrNo" name="SrNo" class="form-control" type="number" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberName" class="form-label">Name</label>
                            <input id="editSubMemberName" name="Name" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberMobileNo" class="form-label">Mobile</label>
                            <input id="editSubMemberMobileNo" name="MobileNo" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberEmailId" class="form-label">Email ID</label>
                            <input id="editSubMemberEmailId" name="EmailId" class="form-control" inputmode="email" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberRelation" class="form-label">Relation</label>
                            <input id="editSubMemberRelation" name="Relation" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="editSubMemberDesignation" class="form-label">Designation</label>
                            <input id="editSubMemberDesignation" name="Designation" class="form-control" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input id="editSubMemberIsActive" name="IsActive" class="form-check-input" type="checkbox" role="switch" value="true" />
                                <input type="hidden" name="IsActive" value="false" />
                                <label for="editSubMemberIsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input id="editSubMemberIsRegistrationFormSubmitted" name="IsRegistrationFormSubmitted" class="form-check-input" type="checkbox" role="switch" value="true" />
                                <input type="hidden" name="IsRegistrationFormSubmitted" value="false" />
                                <label for="editSubMemberIsRegistrationFormSubmitted" class="form-check-label">Registration Form Submitted</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const editModal = document.getElementById('editSubMemberModal');
            if (!editModal) return;

            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                if (!button) return;

                document.getElementById('editSubMemberId').value = button.getAttribute('data-sub-id') || '';
                document.getElementById('editSubMemberSrNo').value = button.getAttribute('data-sub-srno') || '';
                document.getElementById('editSubMemberMemberId').value = button.getAttribute('data-sub-memberid') || '';
                document.getElementById('editSubMemberName').value = button.getAttribute('data-sub-name') || '';
                document.getElementById('editSubMemberMobileNo').value = button.getAttribute('data-sub-mobile') || '';
                document.getElementById('editSubMemberEmailId').value = button.getAttribute('data-sub-email') || '';
                document.getElementById('editSubMemberRelation').value = button.getAttribute('data-sub-relation') || '';
                document.getElementById('editSubMemberDesignation').value = button.getAttribute('data-sub-designation') || '';
                document.getElementById('editSubMemberIsActive').checked = (button.getAttribute('data-sub-active') || '').toLowerCase() === 'true';
                document.getElementById('editSubMemberIsRegistrationFormSubmitted').checked = (button.getAttribute('data-sub-regsubmitted') || '').toLowerCase() === 'true';
            });
        });
    </script>
}
