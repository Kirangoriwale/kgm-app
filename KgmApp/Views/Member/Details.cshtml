@model KgmApp.Models.Member
@{
    ViewData["Title"] = "Member details";
    var subMembers = Model.SubMembers
        .OrderBy(s => s.SrNo)
        .ThenBy(s => s.Name)
        .ThenBy(s => s.MobileNo)
        .ToList();
}

<div class="row g-4">
    <div class="col-12">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Members</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>

        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3 mb-0">
            <h1 class="h3 mb-0">@Model.Name</h1>
            <div class="d-flex flex-wrap gap-2">
                @if (ViewMenu.Can(ViewData, MenuKeys.Members, "Edit"))
                {
                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit / Manage SubMembers</a>
                }
                @if (ViewMenu.Can(ViewData, MenuKeys.Members, "Delete"))
                {
                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Member Information</h2>
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-end text-nowrap">Sr. No.</th>
                                <th>Name</th>
                                <th>Mobile</th>
                                <th>Email ID</th>
                                <th>Address</th>
                                <th>Login Password</th>
                                <th>Role</th>
                                <th class="text-center">Restrict Login</th>
                                <th>Designation</th>
                                <th class="text-center">Active</th>
                                <th class="text-center">Registration</th>
                                <th class="text-center">Is Commitee Member</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-end">@Model.Sr</td>
                                <td class="fw-medium text-break">@Model.Name</td>
                                <td>@Model.MobileNo</td>
                                <td class="text-break">@Model.EmailId</td>
                                <td class="text-break">@Model.Address</td>
                                <td class="text-break">@Model.LoginPassword</td>
                                <td class="text-nowrap">@Model.Role</td>
                                <td class="text-center">
                                    @if (Model.RestrictLogin)
                                    {
                                        <span class="badge member-status-badge member-status-no">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge member-status-badge member-status-yes">No</span>
                                    }
                                </td>
                                <td class="text-break">@Model.Designation</td>
                                <td class="text-center">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge member-status-badge member-status-yes">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge member-status-badge member-status-no">No</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (Model.IsRegistrationFormSubmitted)
                                    {
                                        <span class="badge member-status-badge member-status-yes">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge member-status-badge member-status-no">No</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (Model.IsCommiteeMember)
                                    {
                                        <span class="badge member-status-badge member-status-yes">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge member-status-badge member-status-no">No</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
                <h2 class="h5 mb-0">SubMembers</h2>
            </div>
            <div class="card-body p-0">
                @if (subMembers.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-6 d-block mb-2" aria-hidden="true"></i>
                        No sub-members available for this member.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-end text-nowrap">Sr. No.</th>
                                    <th>Name</th>
                                    <th>Mobile</th>
                                    <th>Email ID</th>
                                    <th>Relation</th>
                                    <th>Designation</th>
                                    <th class="text-center">Active</th>
                                    <th class="text-center">Registration</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var sub in subMembers)
                            {
                                <tr>
                                    <td class="text-end">@sub.SrNo</td>
                                    <td class="fw-medium text-break">@sub.Name</td>
                                    <td>@sub.MobileNo</td>
                                    <td class="text-break">@sub.EmailId</td>
                                    <td>@sub.Relation</td>
                                    <td class="text-break">@sub.Designation</td>
                                    <td class="text-center">
                                        @if (sub.IsActive)
                                        {
                                            <span class="badge member-status-badge member-status-yes">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge member-status-badge member-status-no">No</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (sub.IsRegistrationFormSubmitted)
                                        {
                                            <span class="badge member-status-badge member-status-yes">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge member-status-badge member-status-no">No</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="mt-4">
            <a class="btn btn-outline-secondary" asp-action="Index">Back to Members</a>
        </div>
    </div>
</div>
