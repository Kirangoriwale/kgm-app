@model KgmApp.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Khamgaon</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <style>
        body.auth-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4e89 45%, #0b1220 100%);
            color: #0f172a;
        }

        .auth-shell {
            min-height: 100vh;
            padding: 1.5rem 0.75rem;
        }

        .auth-card {
            border: 1px solid rgba(148, 163, 184, 0.35);
            border-radius: 1.25rem;
            background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
            box-shadow: 0 1.25rem 2.5rem rgba(2, 6, 23, 0.4);
            overflow: hidden;
        }

        .auth-card-body {
            padding: 2rem 1.5rem;
        }

        .auth-title {
            font-weight: 700;
            font-family: "Noto Sans Devanagari", "Mangal", "Nirmala UI", "Segoe UI", sans-serif;
            letter-spacing: 0.015em;
            line-height: 1.35;
            font-size: 1.35rem;
            color: #0f172a;
            text-wrap: balance;
            text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
        }

        .auth-subtitle {
            color: #475569;
        }

        .form-label {
            color: #0f172a;
        }

        .auth-input-group-text {
            background-color: #e2e8f0;
            border-color: #cbd5e1;
            color: #334155;
            border-right: 0;
        }

        .auth-input-group-btn {
            background-color: #e2e8f0;
            border: 1px solid #cbd5e1;
            border-left: 0;
            color: #334155;
        }

        .auth-input-group-btn:hover {
            color: #0f172a;
            background-color: #dbeafe;
        }

        .auth-input {
            border-left: 0 !important;
            border-color: #cbd5e1;
            background-color: #ffffff;
            color: #0f172a;
            padding-top: 0.65rem;
            padding-bottom: 0.65rem;
        }

        .auth-input-with-toggle {
            border-right: 0 !important;
        }

        .auth-input::placeholder {
            color: #64748b;
        }

        .auth-input:focus {
            box-shadow: none;
            background-color: #ffffff;
            color: #0f172a;
        }

        .auth-input-group:focus-within {
            border-radius: 0.65rem;
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.18);
        }

        .auth-input-group:focus-within .auth-input-group-text,
        .auth-input-group:focus-within .auth-input,
        .auth-input-group:focus-within .auth-input-group-btn {
            border-color: #86b7fe;
        }

        .text-danger.validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 1rem;
        }

        .auth-submit {
            padding: 0.65rem 1rem;
            border-radius: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.01em;
        }

        @@media (min-width: 576px) {
            .auth-card-body {
                padding: 2.25rem;
            }

            .auth-title {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body class="auth-page">
    <div class="container auth-shell d-flex align-items-center justify-content-center">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
            <div class="card auth-card">
                <div class="card-body auth-card-body">
                    <div class="text-center mb-4">
                        <h1 class="h4 auth-title mb-1">खामगांव ग्रामस्थ मंडळ, मुंबई</h1>
                        <p class="auth-subtitle mb-0 small">Sign in to continue</p>
                    </div>

                    <form asp-action="Login" method="post" novalidate>
                        @if (TempData["ErrorMessage"] is string loginErr && !string.IsNullOrWhiteSpace(loginErr))
                        {
                            <div class="alert alert-warning" role="alert">@loginErr</div>
                        }
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="MobileNo" class="form-label"></label>
                            <div class="input-group auth-input-group">
                                <span class="input-group-text auth-input-group-text">
                                    <i class="bi bi-phone"></i>
                                </span>
                                <input asp-for="MobileNo" class="form-control auth-input" autocomplete="username" inputmode="numeric" maxlength="10" pattern="\d{10}" title="10-digit mobile number" placeholder="10-digit mobile number" />
                            </div>
                            <span asp-validation-for="MobileNo" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group auth-input-group">
                                <span class="input-group-text auth-input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input asp-for="Password" class="form-control auth-input auth-input-with-toggle" autocomplete="current-password" />
                                <button class="btn auth-input-group-btn"
                                        type="button"
                                        id="togglePasswordBtn"
                                        aria-label="Show password"
                                        aria-controls="Password"
                                        aria-pressed="false">
                                    <i class="bi bi-eye" id="togglePasswordIcon" aria-hidden="true"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary auth-submit w-100">
                            <i class="bi bi-box-arrow-in-right me-1" aria-hidden="true"></i>
                            Login
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const passwordInput = document.getElementById("Password");
            const toggleButton = document.getElementById("togglePasswordBtn");
            const toggleIcon = document.getElementById("togglePasswordIcon");

            if (!passwordInput || !toggleButton || !toggleIcon) return;

            toggleButton.addEventListener("click", function () {
                const isHidden = passwordInput.type === "password";
                passwordInput.type = isHidden ? "text" : "password";
                toggleIcon.className = isHidden ? "bi bi-eye-slash" : "bi bi-eye";
                toggleButton.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
                toggleButton.setAttribute("aria-pressed", isHidden ? "true" : "false");
            });
        })();
    </script>
</body>
</html>
