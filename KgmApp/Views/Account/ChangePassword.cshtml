@model KgmApp.Models.ChangePasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Change password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Change password - Khamgaon</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <style>
        body.auth-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4e89 45%, #0b1220 100%);
            color: #0f172a;
        }
        .auth-shell { min-height: 100vh; padding: 1.5rem 0.75rem; }
        .auth-card {
            border: 1px solid rgba(148, 163, 184, 0.35);
            border-radius: 1.25rem;
            background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
            box-shadow: 0 1.25rem 2.5rem rgba(2, 6, 23, 0.4);
        }
        .auth-card-body { padding: 2rem 1.5rem; }
        .auth-title { font-weight: 700; color: #0f172a; }
        .auth-subtitle { color: #475569; }
        .form-label { color: #0f172a; }
        .auth-input-group-text {
            background-color: #e2e8f0;
            border-color: #cbd5e1;
            color: #334155;
            border-right: 0;
        }
        .auth-input {
            border-left: 0 !important;
            border-color: #cbd5e1;
            background-color: #ffffff;
            color: #0f172a;
        }
        .auth-submit {
            padding: 0.65rem 1rem;
            border-radius: 0.65rem;
            font-weight: 600;
        }
    </style>
</head>
<body class="auth-page">
    <div class="container auth-shell d-flex align-items-center justify-content-center">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
            <div class="card auth-card">
                <div class="card-body auth-card-body">
                    <div class="text-center mb-4">
                        <h1 class="h4 auth-title mb-1">Change password</h1>
                        <p class="auth-subtitle mb-0 small">You must set a new password before continuing.</p>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text auth-input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="CurrentPassword" class="form-control auth-input" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text auth-input-group-text"><i class="bi bi-key"></i></span>
                                <input asp-for="NewPassword" class="form-control auth-input" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text auth-input-group-text"><i class="bi bi-key-fill"></i></span>
                                <input asp-for="ConfirmNewPassword" class="form-control auth-input" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary auth-submit w-100">
                            <i class="bi bi-check2-circle me-1"></i> Save new password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
