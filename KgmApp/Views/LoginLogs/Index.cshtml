@model IReadOnlyList<KgmApp.Models.LoginLog>
@{
    ViewData["Title"] = "Login Logs";
    ViewData["PageTitle"] = "Login Logs";
    ViewData["BreadcrumbCurrent"] = "Login Logs";
    var search = (ViewData["Search"] as string) ?? string.Empty;
    var currentPage = (ViewData["CurrentPage"] as int?) ?? 1;
    var totalPages = (ViewData["TotalPages"] as int?) ?? 1;
    var totalItems = (ViewData["TotalItems"] as int?) ?? 0;
}

<div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 flex-wrap">
        <div class="input-group" style="min-width: 18rem;">
            <span class="input-group-text">
                <i class="bi bi-search" aria-hidden="true"></i>
            </span>
            <input type="search"
                   name="search"
                   value="@search"
                   class="form-control"
                   placeholder="Search username or mobile number" />
        </div>
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <a asp-action="Index" class="btn btn-link text-decoration-none px-0">Clear</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-clock-history display-6 d-block mb-3" aria-hidden="true"></i>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <span>No login logs found for <strong>@search</strong>.</span>
            }
            else
            {
                <span>No login logs found.</span>
            }
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User Name</th>
                        <th>Mobile No</th>
                        <th class="text-nowrap">Login Time</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@row.UserName</td>
                            <td>@row.MobileNo</td>
                            <td class="text-nowrap">@row.LoginTimeUtc.ToLocalTime().ToString("dd MMM yyyy, hh:mm:ss tt")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">Showing page @currentPage of @totalPages (@totalItems total logs)</small>
            <nav aria-label="Login logs pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : string.Empty)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@search"
                           asp-route-page="@(currentPage - 1)">Previous</a>
                    </li>
                    @for (var p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : string.Empty)">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-search="@search"
                               asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : string.Empty)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@search"
                           asp-route-page="@(currentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
}
