@model KgmApp.Models.Transaction
@{
    ViewData["Title"] = "Delete Transaction";
    var party = Model.Member?.Name ?? Model.SubMember?.Name ?? Model.DonorName ?? "-";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Transactions</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <h1 class="h3 text-danger mb-2">Delete Transaction</h1>
        <p class="text-muted mb-4">This action cannot be undone.</p>

        <div class="card border-danger border-opacity-50 shadow-sm mb-4 rounded-3">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.TransactionDate.ToString("dd-MMM-yyyy")</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category</dd>

                    <dt class="col-sm-4">Member / SubMember / Donor</dt>
                    <dd class="col-sm-8 text-break">@party</dd>

                    <dt class="col-sm-4">Amount</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Amount.ToString("0.00")</dd>

                    <dt class="col-sm-4">Payment</dt>
                    <dd class="col-sm-8">@Model.PaymentMode</dd>

                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.Type</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8 text-break">@Model.Description</dd>
                    }
                </dl>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="d-flex flex-column flex-sm-row gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
