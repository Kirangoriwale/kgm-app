@model KgmApp.Models.Meeting
@{
    ViewData["Title"] = "Edit Meeting";
    ViewData["PageTitle"] = "Edit Meeting";
    ViewData["BreadcrumbCurrent"] = "Edit Meeting";
}

@section Head {
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <h1 class="h3 mb-4">Edit Meeting</h1>
        <div class="mb-3 d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            <a class="btn btn-outline-primary" asp-action="MarkAttendance" asp-route-id="@Model.Id">Attendance</a>
            <button type="submit" form="meetingEditForm" class="btn btn-primary">Save</button>
        </div>

        <form asp-action="Edit" method="post" class="card border-0 shadow-sm rounded-3" id="meetingEditForm">
            <input type="hidden" asp-for="Id" />
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label asp-for="MeetingDate" class="form-label"></label>
                        <input asp-for="MeetingDate" type="date" class="form-control" />
                        <span asp-validation-for="MeetingDate" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-8">
                        <label asp-for="Title" class="form-label"></label>
                        <select asp-for="Title" asp-items="ViewBag.MeetingTitles" class="form-select">
                            <option value="">-- Select Meeting Type --</option>
                        </select>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Location" class="form-label"></label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="MinutesOfMeeting" class="form-label"></label>
                        <div id="minutesEditorEdit" class="meeting-minutes-editor"></div>
                        <textarea asp-for="MinutesOfMeeting" class="d-none"></textarea>
                        <span asp-validation-for="MinutesOfMeeting" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script>
        (function () {
            const form = document.getElementById('meetingEditForm');
            const minutesInput = document.getElementById('MinutesOfMeeting');
            const editorHost = document.getElementById('minutesEditorEdit');
            if (!form || !minutesInput || !editorHost || typeof Quill === 'undefined') return;

            const quill = new Quill(editorHost, {
                theme: 'snow',
                placeholder: 'Write minutes of meeting...',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ list: 'ordered' }, { list: 'bullet' }],
                        ['link', 'clean']
                    ]
                }
            });

            if (minutesInput.value) {
                quill.clipboard.dangerouslyPasteHTML(minutesInput.value);
            }

            form.addEventListener('submit', function () {
                const html = quill.root.innerHTML;
                minutesInput.value = html === '<p><br></p>' ? '' : html;
            });
        })();
    </script>
}

