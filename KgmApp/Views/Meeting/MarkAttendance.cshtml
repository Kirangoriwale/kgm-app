@model KgmApp.Models.Meetings.MeetingAttendanceViewModel
@{
    ViewData["Title"] = "Mark Attendance";
    ViewData["PageTitle"] = "Mark Attendance";
    ViewData["BreadcrumbCurrent"] = "Mark Attendance";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.MeetingTitle</h1>
        <div class="text-muted">Meeting Date: @Model.MeetingDate.ToString("dd-MMM-yyyy")</div>
        @if (!string.IsNullOrWhiteSpace(Model.MeetingLocation))
        {
            <div class="text-muted">Location: @Model.MeetingLocation</div>
        }
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to Meetings</a>
</div>

@if (TempData["SuccessMessage"] is string success && !string.IsNullOrWhiteSpace(success))
{
    <div class="alert alert-success" role="alert">@success</div>
}

<form asp-action="MarkAttendance" method="post" class="card border-0 shadow-sm rounded-3">
    <input type="hidden" name="MeetingId" value="@Model.MeetingId" />
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sr</th>
                        <th>Member Name</th>
                        <th>Mobile</th>
                        <th class="text-center">Present</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Members.Count; i++)
                {
                    var row = Model.Members[i];
                    <tr>
                        <td class="text-nowrap">@row.Sr</td>
                        <td class="fw-medium">@row.MemberName</td>
                        <td class="text-nowrap">@row.MobileNo</td>
                        <td class="text-center">
                            <input type="hidden" name="Members[@i].MemberId" value="@row.MemberId" />
                            <input class="form-check-input" type="checkbox" name="Members[@i].IsPresent" value="true" @(row.IsPresent ? "checked" : "") />
                        </td>
                        <td class="text-end">
                            @if (row.AttendanceId.HasValue)
                            {
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger"
                                        formaction="@Url.Action("DeleteAttendance", "Meeting")"
                                        formmethod="post"
                                        formnovalidate
                                        name="attendanceId"
                                        value="@row.AttendanceId.Value">
                                    Delete Mark
                                </button>
                            }
                            else
                            {
                                <span class="text-muted small">Not marked</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top-0 px-4 pb-4 d-flex justify-content-end">
        <button type="submit" class="btn btn-primary">Save Attendance</button>
    </div>
</form>

