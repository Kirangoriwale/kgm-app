@model KgmApp.Models.Suggestion
@{
    ViewData["Title"] = "Delete Suggestion";
    ViewData["PageTitle"] = "Delete Suggestion";
    ViewData["BreadcrumbCurrent"] = "Delete Suggestion";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-3 p-md-4">
                <h2 class="h5 text-danger mb-3">Delete this suggestion?</h2>
                <p class="mb-2"><strong>Title:</strong> @Model.Title</p>
                <p class="mb-2"><strong>Suggestion:</strong> @Model.Content</p>
                <p class="small text-muted mb-0">This action cannot be undone.</p>
            </div>
            <div class="card-footer bg-white border-top-0 px-3 px-md-4 pb-3 pb-md-4 d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
