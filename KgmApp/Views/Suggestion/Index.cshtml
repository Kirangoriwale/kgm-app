@model IReadOnlyList<KgmApp.Models.Suggestion>
@{
    ViewData["Title"] = "Suggestions";
    ViewData["PageTitle"] = "Suggestions";
    ViewData["BreadcrumbCurrent"] = "Suggestions";
    var role = Context.Session.GetString("Role") ?? string.Empty;
    var canAdd = ViewMenu.Can(ViewData, MenuKeys.Suggestions, "Add");
}
@using Microsoft.AspNetCore.Http

@if (canAdd)
{
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3 p-md-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Title" class="form-label fw-semibold">Title</label>
                        <input id="Title" name="Title" class="form-control" maxlength="200" placeholder="Enter title" />
                    </div>
                    <div>
                        <label for="Content" class="form-label fw-semibold">Suggestion</label>
                        <textarea id="Content" name="Content" class="form-control" rows="3" maxlength="2000" placeholder="Write your suggestion..."></textarea>
                    </div>
                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-primary">Submit Suggestion</button>
                </div>
            </form>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox display-6 d-block mb-3" aria-hidden="true"></i>
            No suggestions found.
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var row in Model)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                            <h2 class="h6 mb-0 text-dark">@row.Title</h2>
                            <span class="small text-muted">@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                        </div>
                        @if (!string.Equals(role, "Member", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="small text-muted mb-2">From: @row.MemberName</div>
                        }
                        <div class="text-body">@row.Content</div>
                        @if (ViewMenu.Can(ViewData, MenuKeys.Suggestions, "Delete"))
                        {
                            <div class="mt-3 d-flex justify-content-end">
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@row.Id">Delete</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
