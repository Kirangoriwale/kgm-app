@model KgmApp.Models.AnnouncementIndexViewModel
@{
    ViewData["Title"] = "Announcements";
    ViewData["PageTitle"] = "Announcements";
    ViewData["BreadcrumbCurrent"] = "Announcements";
}

<div class="page-actions d-flex justify-content-end mb-4">
    @if (ViewMenu.Can(ViewData, MenuKeys.Announcements, "Add"))
    {
        <a class="btn btn-primary rounded-3 d-inline-flex align-items-center justify-content-center gap-2" asp-action="Create">
            <i class="bi bi-megaphone" aria-hidden="true"></i>
            Create Announcement
        </a>
    }
</div>

@if (!Model.Items.Any())
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox display-6 d-block mb-3" aria-hidden="true"></i>
            No announcements available.
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @for (var i = 0; i < Model.Items.Count; i++)
        {
            var row = Model.Items[i];
            var colorClass = $"announcement-card--{(i % 4) + 1}";
            var hasContent = !string.IsNullOrWhiteSpace(row.ContentHtml) &&
                !string.Equals(row.ContentHtml.Trim(), "<p><br></p>", StringComparison.OrdinalIgnoreCase);
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3 h-100 @colorClass">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                            <h2 class="h5 mb-0 text-dark">@row.Title</h2>
                            <span class="small text-muted">@row.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                        </div>

                        @if (!hasContent)
                        {
                            <div class="text-muted">No details provided.</div>
                        }
                        else
                        {
                            <div class="text-body announcement-content">@Html.Raw(row.ContentHtml)</div>
                        }

                        @if (ViewMenu.Can(ViewData, MenuKeys.Announcements, "Delete"))
                        {
                            <div class="mt-3 d-flex justify-content-end">
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@row.Id">Delete</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Announcements pages" class="mt-4">
            <ul class="pagination pagination-sm justify-content-center flex-wrap gap-1">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
