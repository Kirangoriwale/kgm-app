@model KgmApp.Models.Announcement
@{
    ViewData["Title"] = "Create Announcement";
    ViewData["PageTitle"] = "Create Announcement";
    ViewData["BreadcrumbCurrent"] = "Create Announcement";
}

@section Head {
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-9">
        <form asp-action="Create" method="post" class="card border-0 shadow-sm rounded-3" id="announcementCreateForm">
            <div class="card-body p-3 p-md-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" maxlength="200" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContentHtml" class="form-label">Announcement Details</label>
                    <div id="announcementEditor" class="meeting-minutes-editor"></div>
                    <textarea asp-for="ContentHtml" class="d-none"></textarea>
                    <span asp-validation-for="ContentHtml" class="text-danger"></span>
                </div>
            </div>
            <div class="card-footer bg-white border-top-0 px-3 px-md-4 pb-3 pb-md-4 d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Create Announcement</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script>
        (function () {
            const form = document.getElementById('announcementCreateForm');
            const hiddenInput = document.getElementById('ContentHtml');
            const editorHost = document.getElementById('announcementEditor');
            if (!form || !hiddenInput || !editorHost || typeof Quill === 'undefined') return;

            const quill = new Quill(editorHost, {
                theme: 'snow',
                placeholder: 'Write announcement details...',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ list: 'ordered' }, { list: 'bullet' }],
                        ['link', 'clean']
                    ]
                }
            });

            if (hiddenInput.value) {
                quill.clipboard.dangerouslyPasteHTML(hiddenInput.value);
            }

            form.addEventListener('submit', function () {
                const html = quill.root.innerHTML;
                hiddenInput.value = html === '<p><br></p>' ? '' : html;
            });
        })();
    </script>
}
