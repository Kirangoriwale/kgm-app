@model KgmApp.Models.FeeSetting
@{
    ViewData["Title"] = "Edit Fee Setting";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Fee Settings</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>

        <h1 class="h3 mb-4">Edit Fee Setting</h1>

        <form asp-action="Edit" method="post" class="card border-0 shadow-sm rounded-3">
            <input type="hidden" asp-for="Id" />
            <div class="card-body p-4">
                <partial name="_FeeSettingFormFields" model="Model" />
            </div>
            <div class="card-footer bg-white border-top-0 px-4 pb-4 d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

