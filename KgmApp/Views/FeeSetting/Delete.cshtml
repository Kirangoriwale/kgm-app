@model KgmApp.Models.FeeSetting
@{
    ViewData["Title"] = "Delete Fee Setting";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Fee Settings</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <h1 class="h3 text-danger mb-2">Delete Fee Setting</h1>
        <p class="text-muted mb-4">This action cannot be undone.</p>

        <div class="card border-danger border-opacity-50 shadow-sm mb-4 rounded-3">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Apply From Date</dt>
                    <dd class="col-sm-7">@Model.ApplyFromDate.ToString("dd-MMM-yyyy")</dd>

                    <dt class="col-sm-5">Contribution Fee</dt>
                    <dd class="col-sm-7">@Model.ContributionFee.ToString("0.00")</dd>

                    <dt class="col-sm-5">Registration Fee</dt>
                    <dd class="col-sm-7">@Model.RegistrationFee.ToString("0.00")</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="d-flex flex-column flex-sm-row gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>

