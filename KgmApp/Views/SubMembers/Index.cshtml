@model IReadOnlyList<KgmApp.Models.SubMember>
@{
    ViewData["Title"] = "SubMembers";
    ViewData["PageTitle"] = "SubMembers";
    ViewData["BreadcrumbCurrent"] = "SubMembers";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-white border-0 py-3 px-4 rounded-top-3">
        <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-3">
            <p class="text-muted small mb-0 d-none d-md-block">Family sub-members linked to main members.</p>
            <a class="btn btn-primary rounded-3 d-inline-flex align-items-center justify-content-center gap-2" asp-action="Create">
                <i class="bi bi-person-plus" aria-hidden="true"></i>
                <span>Add SubMember</span>
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5 px-4">
                <div class="text-muted mb-3">
                    <i class="bi bi-inbox display-4" aria-hidden="true"></i>
                </div>
                <h2 class="h5 text-dark">No sub-members yet</h2>
                <p class="text-muted mb-4 small mx-auto" style="max-width: 26rem;">Add a sub-member to see them listed here. You can also check your database connection if data is missing.</p>
                <a class="btn btn-primary rounded-3 d-inline-flex align-items-center gap-2" asp-action="Create">
                    <i class="bi bi-person-plus" aria-hidden="true"></i>
                    Add SubMember
                </a>
            </div>
        }
        else
        {
            <div class="p-3 p-md-4 border-bottom bg-body-secondary bg-opacity-50">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="visually-hidden" for="subMemberSearch">Search</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-search" aria-hidden="true"></i></span>
                            <input type="search" id="subMemberSearch" class="form-control border-start-0 rounded-end-3" placeholder="Search name, mobile, member…" autocomplete="off" data-table-search="subMembersTable" />
                        </div>
                    </div>
                    <div class="col-12 col-md-auto ms-md-auto">
                        <p class="small text-muted mb-0" id="subMembersTableInfo" aria-live="polite"></p>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0" id="subMembersTable">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Member</th>
                            <th scope="col" class="text-nowrap">Mobile No</th>
                            <th scope="col">Relation</th>
                            <th scope="col" class="text-center">Active</th>
                            <th scope="col">Designation</th>
                            <th scope="col" class="text-end text-nowrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        var memberName = item.Member?.Name ?? "—";
                        <tr>
                            <td class="fw-medium">@item.Name</td>
                            <td><span class="text-muted">@memberName</span></td>
                            <td>@item.MobileNo</td>
                            <td>@item.Relation</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill text-bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill text-bg-secondary">No</span>
                                }
                            </td>
                            <td class="small">@item.Designation</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm flex-wrap justify-content-end" role="group">
                                    <a href="#" class="btn btn-warning rounded-3 d-inline-flex align-items-center gap-1" title="Edit" onclick="return false;">
                                        <i class="bi bi-pencil" aria-hidden="true"></i><span class="d-none d-xl-inline">Edit</span>
                                    </a>
                                    <a href="#" class="btn btn-danger rounded-3 d-inline-flex align-items-center gap-1" title="Delete" onclick="return false;">
                                        <i class="bi bi-trash" aria-hidden="true"></i><span class="d-none d-xl-inline">Delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-3 px-3 py-3 px-md-4 border-top bg-white rounded-bottom-3">
                <nav aria-label="SubMembers pagination" class="order-2 order-sm-1">
                    <ul class="pagination pagination-sm mb-0" id="subMembersPagination"></ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    @if (Model.Count > 0)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                window.kgmInitTablePage({ tableId: 'subMembersTable', searchInputId: 'subMemberSearch', paginationId: 'subMembersPagination', infoId: 'subMembersTableInfo', pageSize: 5 });
            });
        </script>
    }
}
